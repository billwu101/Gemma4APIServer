# ── Ollama 後端 ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# 這台 VM 的 CUDA 已通，26b 可整顆上 GPU；若換回會死鎖的 VM 請改 gemma4:12b 或走 CPU
DEFAULT_MODEL=gemma4:26b

# gemma4 是 thinking 模型；保持 false，chat 才會回答案而非空字串
ENABLE_THINKING=false

# ── 閘道器綁定 ──────────────────────────────────────────────
# 只綁 localhost，對外一律走 Cloudflare Tunnel，不要綁 0.0.0.0
HOST=127.0.0.1
PORT=8000

# ── 金鑰（多把，逗號分隔）─────────────────────────────────
# 格式 name:key，name 只用於用量記錄；產生金鑰：
#   python -c "import secrets; print('sk-'+secrets.token_hex(24))"
API_KEYS=alice:sk-CHANGE_ME_1,bob:sk-CHANGE_ME_2

# ── 用量資料庫 ──────────────────────────────────────────────
DB_PATH=usage.db
